node_modules/

# Build outputs
dist/
build/
out/
*.tsbuildinfo

# IDEs and editors
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.project
.classpath
.settings/
